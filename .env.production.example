# Скопируйте в .env перед деплоем: cp .env.production.example .env
# Сгенерируйте секреты: ./scripts/generate-secrets.sh

# === Публичный URL сайта (HTTPS) ===
APP_URL=https://cyber.logos.ru
APP_PORT=3000

# === PostgreSQL ===
POSTGRES_USER=cyber
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=cyber_intensive
# Только для локального доступа к БД с хоста (dev/backup). В prod используйте docker-compose.prod.yml
POSTGRES_PORT=5432

# === Админ-панель ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_MIN_12
ADMIN_SESSION_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_32

# За nginx/Caddy — обязательно true
TRUST_PROXY=true

# === Яндекс Smart Captcha ===
NEXT_PUBLIC_YANDEX_CAPTCHA_CLIENT_KEY=ysc1_QkcHig8PAeWbT4inPDSQY51gR3eogniUuArWaWw55011801a
YANDEX_CAPTCHA_SERVER_KEY=ysc2_ВСТАВЬТЕ_СЕРВЕРНЫЙ_КЛЮЧ

# === Почта (обязательно smtp в production) ===
# Yahoo: нужен пароль приложения (Account Security → Generate app password)
EMAIL_MODE=smtp
EMAIL_FROM=nedima21@yahoo.com
SMTP_HOST=smtp.mail.yahoo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=nedima21@yahoo.com
