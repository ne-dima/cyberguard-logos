generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationStatus {
  new
  accepted
  rejected
}

model Application {
  id               String            @id @default(uuid())
  fullName         String
  birthDate        String
  organization     String
  phone            String
  email            String
  parentContacts   String
  location         String
  motivationLetter String
  photoPath        String
  about            String?
  wantsToEnroll    Boolean           @default(false)
  status           ApplicationStatus @default(new)
  rejectionComment String?
  invitationSentAt DateTime?
  consents         Json?
  createdAt        DateTime          @default(now())

  @@index([email])
  @@index([status])
  @@index([createdAt])
}
