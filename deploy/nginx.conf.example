# Пример reverse-proxy для nginx.
# Приложение слушает 127.0.0.1:3000 (docker-compose.prod.yml).

server {
    listen 443 ssl http2;
    server_name cyber.logos.ru;

    # ssl_certificate /etc/letsencrypt/live/cyber.logos.ru/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/cyber.logos.ru/privkey.pem;

    client_max_body_size 6M;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
